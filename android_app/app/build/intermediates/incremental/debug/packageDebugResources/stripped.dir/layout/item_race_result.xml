<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardCornerRadius="8dp"
    app:cardElevation="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Название гонки -->
        <TextView
            android:id="@+id/textRaceName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Название гонки"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/primary"
            tools:text="Гонка преследования Кубок Содружества" />

        <!-- Место проведения -->
        <TextView
            android:id="@+id/textRacePlace"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Место проведения"
            android:textSize="14sp"
            android:textColor="@color/secondary_text"
            android:layout_marginTop="2dp"
            tools:text="Сочи" />

        <!-- Дата и дисциплина -->
        <TextView
            android:id="@+id/textDateDiscipline"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Дата • Дисциплина"
            android:textSize="14sp"
            android:textColor="@color/secondary_text"
            android:layout_marginTop="2dp"
            android:layout_marginBottom="8dp"
            tools:text="2026-02-12 • Гонка преследования" />

        <!-- Стартовый номер -->
        <TextView
            android:id="@+id/textStartNumber"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Стартовый номер: "
            android:textSize="14sp"
            android:layout_marginTop="4dp"
            tools:text="Стартовый номер: 4" />

        <!-- Место на финише -->
        <TextView
            android:id="@+id/textFinishPlace"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Место: "
            android:textSize="14sp"
            android:layout_marginTop="2dp"
            tools:text="Место: 7" />

        <!-- Количество промахов -->
        <TextView
            android:id="@+id/textMissCount"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Промахи: "
            android:textSize="14sp"
            android:layout_marginTop="2dp"
            android:layout_marginBottom="8dp"
            tools:text="Промахи: 3" />

        <!-- Разделительная линия (опционально) -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/divider"
            android:layout_marginVertical="8dp"
            android:visibility="gone" />

        <!-- PDF Download Button -->
        <Button
            android:id="@+id/buttonDownloadPdf"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="📄 Скачать протокол"
            android:backgroundTint="@color/primary"
            android:textColor="@android:color/white"
            android:visibility="gone"
            app:cornerRadius="20dp" />

    </LinearLayout>

</androidx.cardview.widget.CardView>