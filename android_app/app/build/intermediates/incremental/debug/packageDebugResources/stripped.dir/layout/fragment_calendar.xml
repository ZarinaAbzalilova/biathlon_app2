<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@android:color/white">

    <!-- Заголовок с месяцем и стрелками -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="16dp">

        <ImageButton
            android:id="@+id/buttonPrevMonth"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_arrow_left"
            android:background="?selectableItemBackgroundBorderless"
            android:contentDescription="Предыдущий месяц" />

        <TextView
            android:id="@+id/textMonthYear"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="Март 2026"
            android:textSize="20sp"
            android:textStyle="bold" />

        <ImageButton
            android:id="@+id/buttonNextMonth"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_arrow_right"
            android:background="?selectableItemBackgroundBorderless"
            android:contentDescription="Следующий месяц" />

    </LinearLayout>

    <!-- Дни недели -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="8dp"
        android:paddingVertical="8dp"
        android:background="#F5F5F5">

        <TextView
            android:id="@+id/textMon"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="ПН"
            android:textStyle="bold"
            android:textColor="#2196F3"/>

        <TextView
            android:id="@+id/textTue"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="ВТ"
            android:textStyle="bold"
            android:textColor="#2196F3"/>

        <TextView
            android:id="@+id/textWed"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="СР"
            android:textStyle="bold"
            android:textColor="#2196F3"/>

        <TextView
            android:id="@+id/textThu"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="ЧТ"
            android:textStyle="bold"
            android:textColor="#2196F3"/>

        <TextView
            android:id="@+id/textFri"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="ПТ"
            android:textStyle="bold"
            android:textColor="#2196F3"/>

        <TextView
            android:id="@+id/textSat"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="СБ"
            android:textStyle="bold"
            android:textColor="#F44336"/>

        <TextView
            android:id="@+id/textSun"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="ВС"
            android:textStyle="bold"
            android:textColor="#F44336" />

    </LinearLayout>

    <!-- Сетка календаря -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerCalendar"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="8dp" />

</LinearLayout>